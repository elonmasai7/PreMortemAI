APP_NAME=PreMortem AI
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://premortem:premortem@localhost:5432/premortem
DATABASE_ECHO=false

AUTH_REQUIRED=false
AUTH_SECRET_KEY=change-me-in-production
AUTH_ACCESS_TOKEN_MINUTES=60
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=admin12345
AUTH_OIDC_ENABLED=false
AUTH_OIDC_CLIENT_ID=
AUTH_OIDC_CLIENT_SECRET=
AUTH_OIDC_DISCOVERY_URL=
AUTH_OIDC_REDIRECT_URI=http://127.0.0.1:8000/api/auth/oidc/callback
AUTH_OIDC_DEFAULT_ROLE=viewer

REDIS_URL=redis://localhost:6379/0
QUEUE_ENABLED=false
QUEUE_NAME=investigations
CACHE_TTL_SECONDS=60
RATE_LIMIT_WINDOW_SECONDS=60
TENANT_USAGE_QUOTA_PER_MINUTE=600
REMEDIATION_MIN_EVIDENCE_FOR_APPROVAL=1
REMEDIATION_RESTRICTED_KEYWORDS=drop database,terraform destroy,rm -rf
COMPLIANCE_RETENTION_DAYS=90
COMPLIANCE_ENABLE_AUDIT_EXPORT=true
KMS_PROVIDER=
KMS_KEY_ID=
TRACING_ENABLED=true
TRACING_EXPORTER=none
SLO_SUCCESS_TARGET_PERCENT=99.5
SLO_LATENCY_TARGET_MS=1500

SPLUNK_BASE_URL=https://localhost:8089
SPLUNK_USERNAME=
SPLUNK_PASSWORD=
SPLUNK_TOKEN=
SPLUNK_VERIFY_SSL=false
SPLUNK_DEFAULT_INDEX=
SPLUNK_TIMEOUT_SECONDS=60

MCP_SERVER_URL=
MCP_ENABLED=false

AI_PROVIDER=disabled
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

LOG_LEVEL=INFO
